<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Force light theme to match website (website has no dark mode) -->
    <style name="Base.Theme.LearnExpress" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryContainer">@color/primaryTint</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">@color/primaryLight</item>
        <item name="android:colorBackground">@color/bg</item>
        <item name="android:textColorPrimary">@color/text</item>
        <item name="android:textColorSecondary">@color/muted</item>
        <item name="android:statusBarColor">@color/bg</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
</resources>