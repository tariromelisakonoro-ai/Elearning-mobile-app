<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <!-- Top Navigation Bar -->
    <include
        android:id="@+id/nav_bar"
        layout="@layout/nav_header"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:id="@+id/communityScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/footer"
        app:layout_constraintTop_toBottomOf="@id/nav_bar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Subtitle -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="48dp"
                android:letterSpacing="0.1"
                android:text="CONNECT &amp; COLLABORATE"
                android:textColor="@color/primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- Hero Title -->
            <TextView
                android:id="@+id/communityHeroTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:lineSpacingExtra="8dp"
                android:text="Your learning community starts here."
                android:textColor="@color/heading"
                android:textSize="32sp"
                android:textStyle="bold" />

            <!-- Hero Description -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:text="Ask questions, get answers, read announcements, and grow alongside your peers and instructors — all in one place."
                android:textColor="@color/muted"
                android:textSize="16sp" />

            <!-- Buttons Row -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnNavAnnouncements"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="16dp"
                    android:background="@drawable/btn_orange"
                    android:paddingHorizontal="20dp"
                    android:text="📢 Announcements"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnNavAsk"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/btn_gray"
                    android:paddingHorizontal="20dp"
                    android:text="💡 Post Question"
                    android:textAllCaps="false"
                    android:textColor="@color/heading"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Jump to section -->
            <TextView
                android:id="@+id/sectionJump"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="60dp"
                android:gravity="center"
                android:text="Jump to a section"
                android:textColor="@color/heading"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="Click a card to filter the Q&amp;A feed."
                android:textColor="@color/muted"
                android:textSize="15sp" />

            <!-- Cards Row -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="24dp"
                    android:paddingHorizontal="8dp">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardAllDiscussions"
                        android:layout_width="200dp"
                        android:layout_height="240dp"
                        android:layout_marginEnd="16dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="2dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/grad_purple"
                            android:orientation="vertical"
                            android:padding="20dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💬" android:textSize="28sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="All Discussions" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Browse all community questions." android:textColor="#E0E7FF" android:textSize="13sp"/>
                            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="View all →" android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardMath"
                        android:layout_width="200dp"
                        android:layout_height="240dp"
                        android:layout_marginEnd="16dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="2dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/grad_orange"
                            android:orientation="vertical"
                            android:padding="20dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔢" android:textSize="28sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Mathematics" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Get help with any maths topic." android:textColor="#FEF3C7" android:textSize="13sp"/>
                            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Browse Maths →" android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardSciences"
                        android:layout_width="200dp"
                        android:layout_height="240dp"
                        android:layout_marginEnd="16dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="2dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/grad_green"
                            android:orientation="vertical"
                            android:padding="20dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔬" android:textSize="28sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Sciences" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Study support for science subjects." android:textColor="#D1FAE5" android:textSize="13sp"/>
                            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Browse Sciences →" android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardEnglish"
                        android:layout_width="200dp"
                        android:layout_height="240dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="2dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/grad_pink"
                            android:orientation="vertical"
                            android:padding="20dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📖" android:textSize="28sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="English" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Language study and essay threads." android:textColor="#FCE7F3" android:textSize="13sp"/>
                            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Browse English →" android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>
            </HorizontalScrollView>

            <!-- Latest Announcements Section -->
            <LinearLayout
                android:id="@+id/sectionAnnouncements"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="48dp"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📢"
                        android:textSize="24sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="Latest Announcements"
                        android:textColor="@color/heading"
                        android:textSize="24sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:paddingHorizontal="24dp"
                    android:text="Stay informed with the latest platform updates and messages from your instructors and administration."
                    android:textColor="@color/muted"
                    android:textSize="15sp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerAnnouncements"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:nestedScrollingEnabled="false"
                    android:paddingHorizontal="24dp" />

                <TextView
                    android:id="@+id/tvNoAnnouncements"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="40dp"
                    android:text="Could not load announcements."
                    android:textColor="@color/muted"
                    android:textSize="15sp"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- Community Q&A Section -->
            <LinearLayout
                android:id="@+id/sectionQA"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="60dp"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💬"
                        android:textSize="24sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="Community Q&amp;A"
                        android:textColor="@color/heading"
                        android:textSize="24sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:paddingHorizontal="24dp"
                    android:text="Browse questions posted by students and instructors. Click a subject filter or a pillar card above to narrow the feed."
                    android:textColor="@color/muted"
                    android:textSize="15sp" />

                <!-- Subject Filters -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:scrollbars="none">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="4dp">
                        <TextView android:id="@+id/filterAll" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="All" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:background="@drawable/chip_outline" android:layout_margin="4dp" android:textColor="@color/heading" android:textStyle="bold" />
                        <TextView android:id="@+id/filterMath" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Math" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:background="@drawable/chip_outline" android:layout_margin="4dp" android:textColor="@color/heading" android:textStyle="bold" />
                        <TextView android:id="@+id/filterSciences" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sciences" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:background="@drawable/chip_outline" android:layout_margin="4dp" android:textColor="@color/heading" android:textStyle="bold" />
                        <TextView android:id="@+id/filterEnglish" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="English" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:background="@drawable/chip_outline" android:layout_margin="4dp" android:textColor="@color/heading" android:textStyle="bold" />
                        <TextView android:id="@+id/filterHistory" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="History" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:background="@drawable/chip_outline" android:layout_margin="4dp" android:textColor="@color/heading" android:textStyle="bold" />
                        <TextView android:id="@+id/filterBusiness" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Business" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:background="@drawable/chip_outline" android:layout_margin="4dp" android:textColor="@color/heading" android:textStyle="bold" />
                        <TextView android:id="@+id/filterCS" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CS" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:background="@drawable/chip_outline" android:layout_margin="4dp" android:textColor="@color/heading" android:textStyle="bold" />
                        <TextView android:id="@+id/filterOther" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Other" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:background="@drawable/chip_outline" android:layout_margin="4dp" android:textColor="@color/heading" android:textStyle="bold" />
                    </LinearLayout>
                </HorizontalScrollView>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerQuestions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:nestedScrollingEnabled="false"
                    android:paddingHorizontal="24dp" />

                <TextView
                    android:id="@+id/tvNoQuestions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="40dp"
                    android:text="Could not load questions."
                    android:textColor="@color/muted"
                    android:textSize="15sp"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- Collaboration Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="60dp"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="COLLABORATION TOOLS"
                    android:textColor="@color/primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center"
                    android:text="Work together, grow together."
                    android:textColor="@color/heading"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:scrollbars="none">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp">
                        <include android:id="@+id/collabWeekly" layout="@layout/item_collab_feature" />
                        <include android:id="@+id/collabTeacher" layout="@layout/item_collab_feature" />
                        <include android:id="@+id/collabLive" layout="@layout/item_collab_feature" />
                        <include android:id="@+id/collabBuddy" layout="@layout/item_collab_feature" />
                    </LinearLayout>
                </HorizontalScrollView>
            </LinearLayout>

            <!-- Explore Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="60dp"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Explore more of LearnExpress"
                    android:textColor="@color/heading"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:scrollbars="none">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp">
                        <include android:id="@+id/exploreCourses" layout="@layout/item_explore_card" />
                        <include android:id="@+id/exploreAssignments" layout="@layout/item_explore_card" />
                        <include android:id="@+id/exploreExams" layout="@layout/item_explore_card" />
                        <include android:id="@+id/exploreResources" layout="@layout/item_explore_card" />
                    </LinearLayout>
                </HorizontalScrollView>
            </LinearLayout>

            <!-- Ask the Community Section -->
            <androidx.cardview.widget.CardView
                android:id="@+id/sectionAsk"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="60dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="28dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💡"
                            android:textSize="24sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="Ask the Community"
                            android:textColor="@color/heading"
                            android:textSize="24sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Have a question about coursework, exams, or study techniques? Post it below — peers and instructors will respond."
                        android:textColor="@color/muted"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp" />

                    <EditText
                        android:id="@+id/etQuestionTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:background="@drawable/input_bg"
                        android:hint="Your question title..."
                        android:padding="16dp"
                        android:textColor="@color/heading"
                        android:textColorHint="@color/muted"
                        android:textSize="15sp"
                        android:inputType="text" />

                    <RelativeLayout
                        android:id="@+id/btnSubjectPicker"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/input_bg"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="4dp">
                        <TextView
                            android:id="@+id/tvSpinnerPlaceholder"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:gravity="center_vertical"
                            android:text="Select a subject area..."
                            android:textColor="@color/heading"
                            android:textSize="15sp" />
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_chevron_down"
                            app:tint="@color/muted" />
                    </RelativeLayout>

                    <EditText
                        android:id="@+id/etQuestionDetail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/input_bg"
                        android:gravity="top"
                        android:hint="Describe your question in detail..."
                        android:minLines="5"
                        android:padding="16dp"
                        android:textColor="@color/heading"
                        android:textColorHint="@color/muted"
                        android:textSize="15sp"
                        android:inputType="textMultiLine" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnPostQuestion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:background="@drawable/btn_orange"
                        android:text="Post Question"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Bottom Spacer -->
            <View
                android:layout_width="match_parent"
                android:layout_height="80dp" />

        </LinearLayout>
    </ScrollView>

    <!-- Footer -->
    <LinearLayout
        android:id="@+id/footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/footer_bg"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingVertical="24dp"
        android:gravity="center_vertical"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="© 2026 LearnExpress. Learn more, study better, and stay ahead."
            android:textColor="@color/footerText"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvBackToHome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Back to home"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:padding="8dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
