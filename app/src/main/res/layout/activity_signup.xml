<?xml version="1.0" encoding="utf-8"?>
<!-- Website: .auth-page { min-height: calc(100vh - 84px); padding: 4rem 0 } -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal">

        <!-- Brand Badge -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/brand_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp"
            android:layout_gravity="start">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_logo_learnexpress"
                android:contentDescription="LearnExpress Logo" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="LearnExpress"
                android:textColor="@color/heading"
                android:textSize="18sp"
                android:textStyle="bold"
                android:letterSpacing="0.02" />
        </LinearLayout>

        <!-- Auth Panel Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/auth_panel_bg"
            android:orientation="vertical"
            android:padding="24dp"
            android:elevation="8dp">

            <!-- Title -->
            <TextView
                android:text="Create your LearnExpress account"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/heading"
                android:layout_marginBottom="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <!-- Subtitle -->
            <TextView
                android:text="Choose a role and set up your secure access to student, instructor, administrator, or parent features."
                android:textSize="14sp"
                android:textColor="@color/muted"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="24dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <!-- Full Name -->
            <TextView
                android:text="Full name"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/heading"
                android:layout_marginBottom="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <EditText
                android:id="@+id/etName"
                android:hint="Jane Doe"
                android:inputType="textPersonName"
                android:background="@drawable/input_bg"
                android:padding="16dp"
                android:textSize="15sp"
                android:textColor="@color/heading"
                android:textColorHint="@color/muted"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"/>

            <!-- Email -->
            <TextView
                android:text="Email address"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/heading"
                android:layout_marginBottom="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <EditText
                android:id="@+id/etEmail"
                android:hint="name@example.com"
                android:inputType="textEmailAddress"
                android:background="@drawable/input_bg"
                android:padding="16dp"
                android:textSize="15sp"
                android:textColor="@color/heading"
                android:textColorHint="@color/muted"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"/>

            <!-- Password -->
            <TextView
                android:text="Password"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/heading"
                android:layout_marginBottom="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:hintEnabled="false"
                app:passwordToggleEnabled="true"
                app:passwordToggleTint="@color/muted">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Enter a secure password"
                    android:inputType="textPassword"
                    android:background="@drawable/input_bg"
                    android:padding="16dp"
                    android:textSize="15sp"
                    android:textColor="@color/heading"
                    android:textColorHint="@color/muted"/>

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Confirm Password -->
            <TextView
                android:text="Confirm password"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/heading"
                android:layout_marginBottom="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:hintEnabled="false"
                app:passwordToggleEnabled="true"
                app:passwordToggleTint="@color/muted">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etConfirmPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Re-enter your password"
                    android:inputType="textPassword"
                    android:background="@drawable/input_bg"
                    android:padding="16dp"
                    android:textSize="15sp"
                    android:textColor="@color/heading"
                    android:textColorHint="@color/muted"/>

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Role Selector -->
            <TextView
                android:text="Select your role"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/heading"
                android:layout_marginBottom="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/roleInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:hintEnabled="false"
                app:endIconMode="custom"
                app:endIconDrawable="@drawable/ic_chevron_down"
                app:endIconTint="@color/heading">

                <AutoCompleteTextView
                    android:id="@+id/spinnerRole"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Choose a role"
                    android:inputType="none"
                    android:background="@drawable/input_bg"
                    android:padding="16dp"
                    android:textSize="15sp"
                    android:textColor="@color/heading"
                    android:textColorHint="@color/muted"
                    android:focusable="false"
                    android:clickable="true"
                    android:dropDownVerticalOffset="2dp"
                    android:dropDownHeight="wrap_content"/>

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Remember Me -->
            <CheckBox
                android:id="@+id/cbRememberMe"
                android:text="Remember me"
                android:textColor="@color/heading"
                android:textSize="14sp"
                android:buttonTint="@color/primary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"/>

            <!-- Sign Up Button + Link -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="28dp">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnSignup"
                    android:text="Sign Up"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:background="@drawable/btn_orange"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:paddingStart="28dp"
                    android:paddingEnd="28dp"
                    android:layout_marginEnd="16dp"
                    android:textAllCaps="false"
                    android:elevation="4dp"/>

                <TextView
                    android:id="@+id/tvGoToLogin"
                    android:text="Already have an account? Sign in"
                    android:textColor="@color/primary"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

            <!-- Divider -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/border"/>

                <TextView
                    android:text="  OR SIGN UP WITH  "
                    android:textSize="11sp"
                    android:textColor="@color/muted"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/border"/>

            </LinearLayout>

            <!-- Google Button -->
            <LinearLayout
                android:id="@+id/btnGoogle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/input_bg"
                android:padding="14dp"
                android:layout_marginBottom="12dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_google"
                    android:layout_marginEnd="10dp"
                    android:contentDescription="Google Logo"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/google"
                    android:textColor="@color/heading"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

            </LinearLayout>

            <!-- GitHub Button -->
            <LinearLayout
                android:id="@+id/btnGithub"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/input_bg"
                android:padding="14dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_github"
                    android:layout_marginEnd="10dp"
                    android:contentDescription="GitHub Logo"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/github"
                    android:textColor="@color/heading"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>