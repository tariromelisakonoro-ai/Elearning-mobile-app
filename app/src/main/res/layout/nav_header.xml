<?xml version="1.0" encoding="utf-8"?>
<!-- Website: .site-header { sticky, backdrop-filter blur, white 96%, bottom border } -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/header_bg"
    android:elevation="2dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp"
    android:paddingVertical="14dp">

    <!-- Logo Section: .brand { background: rgba(255,122,26,0.08); border-radius: 1.5rem } -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/brand_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_logo_learnexpress"
            android:contentDescription="LearnExpress Logo" />

        <!-- Website: .brand span { font-weight: 800; font-size: 1.25rem } -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="LearnExpress"
            android:textColor="@color/heading"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="0.02" />
    </LinearLayout>

    <!-- Navigation Links: .main-nav { gap: 0.75rem } -->
    <HorizontalScrollView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Website: .main-nav a { color: var(-muted); font-size: 0.95rem } -->
            <TextView
                android:id="@+id/navHome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:text="Home"
                android:textColor="@color/primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/navCourses"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:text="Courses"
                android:textColor="@color/muted"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/navAssignments"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:text="Assignments"
                android:textColor="@color/muted"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/navExams"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:text="Exams"
                android:textColor="@color/muted"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/navResources"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:text="Resources"
                android:textColor="@color/muted"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/navCommunity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:text="Community"
                android:textColor="@color/muted"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/navSignIn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:text="Sign In"
                android:textColor="@color/muted"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/navSignUp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:text="Sign Up"
                android:textColor="@color/muted"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvSignOut"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:text="Sign Out"
                android:textColor="@color/errorRed"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>
    </HorizontalScrollView>

</LinearLayout>