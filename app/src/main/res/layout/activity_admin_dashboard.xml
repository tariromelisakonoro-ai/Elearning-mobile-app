<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F9FB">

    <include layout="@layout/nav_header" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Admin Profile Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            android:backgroundTint="#FFFFFF"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="32dp">

                <!-- Avatar Circle -->
                <androidx.cardview.widget.CardView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    app:cardCornerRadius="50dp"
                    app:cardElevation="4dp"
                    android:backgroundTint="#F97316"
                    android:layout_marginBottom="16dp">
                    <TextView
                        android:id="@+id/tvAdminInitial"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="P"
                        android:textColor="#FFFFFF"
                        android:textSize="48sp"
                        android:textStyle="bold"
                        android:gravity="center"/>
                </androidx.cardview.widget.CardView>

                <!-- Admin Name -->
                <TextView
                    android:id="@+id/tvAdminName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Precious"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#1a2a4a"
                    android:layout_marginBottom="4dp"/>

                <!-- Role Text -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="System Administrator"
                    android:textSize="16sp"
                    android:textColor="#F97316"
                    android:textStyle="bold"
                    android:layout_marginBottom="24dp"/>

                <!-- Info Box -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    android:backgroundTint="#F8F9FA">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingVertical="8dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Email"
                                android:textStyle="bold"
                                android:textColor="#1a2a4a"/>
                            <TextView
                                android:id="@+id/tvAdminEmail"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="precious@gmail.com"
                                android:textColor="#6B7280"
                                android:textStyle="italic"/>
                        </RelativeLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E5E7EB" android:layout_marginVertical="4dp"/>

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingVertical="8dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Privilege Level"
                                android:textStyle="bold"
                                android:textColor="#1a2a4a"
                                android:layout_centerVertical="true"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="Super Admin"
                                android:textColor="#166534"
                                android:background="@drawable/status_bg"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="4dp"
                                android:textSize="12sp"
                                android:textStyle="bold"/>
                        </RelativeLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Statistics Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp"
            android:gravity="center">

            <!-- Total Students -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView android:id="@+id/tvStatsStudents" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#F97316" android:textSize="24sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Total Students" android:textColor="#6B7280" android:textSize="11sp" android:textStyle="italic"/>
            </LinearLayout>

            <!-- Instructors -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView android:id="@+id/tvStatsInstructors" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#1a2a4a" android:textSize="24sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Instructors" android:textColor="#6B7280" android:textSize="11sp" android:textStyle="italic"/>
            </LinearLayout>

            <!-- Courses -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView android:id="@+id/tvStatsCourses" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#059669" android:textSize="24sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Courses" android:textColor="#6B7280" android:textSize="11sp" android:textStyle="italic"/>
            </LinearLayout>

            <!-- Enrollments -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView android:id="@+id/tvStatsEnrollments" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#DC2626" android:textSize="24sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Enrollments" android:textColor="#6B7280" android:textSize="11sp" android:textStyle="italic"/>
            </LinearLayout>
        </LinearLayout>

        <!-- User Management Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            android:backgroundTint="#FFFFFF"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="User Management"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#1a2a4a"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Approve, block, suspend, or reset passwords for system users."
                    android:textSize="12sp"
                    android:textColor="#6B7280"
                    android:textStyle="italic"
                    android:layout_marginBottom="20dp"/>

                <!-- Header Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:background="#F8F9FA"
                    android:layout_marginBottom="12dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:text="Name" android:textStyle="bold" android:textColor="#1a2a4a" android:textSize="12sp"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Role" android:textStyle="bold" android:textColor="#1a2a4a" android:textSize="12sp"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Status" android:textStyle="bold" android:textColor="#1a2a4a" android:textSize="12sp"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:text="Actions" android:textStyle="bold" android:textColor="#1a2a4a" android:textSize="12sp" android:gravity="end"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/containerUserManagement"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <!-- Dynamic users list injected here -->
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false">
            
            <!-- Enrollment Control -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                android:layout_marginEnd="8dp"
                android:backgroundTint="#FFFFFF"
                android:layout_marginBottom="24dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Enrollment Control"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#1a2a4a"
                        android:layout_marginBottom="12dp"/>
                        
                    <LinearLayout
                        android:id="@+id/containerEnrollmentControl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Loading..." android:textColor="#6B7280" android:textSize="12sp" android:textStyle="italic"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            
            <!-- Post Notification -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                android:layout_marginStart="8dp"
                android:backgroundTint="#FFFFFF"
                android:layout_marginBottom="24dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Post Notification"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#1a2a4a"
                        android:layout_marginBottom="4dp"/>
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Send an announcement to platform users."
                        android:textSize="12sp"
                        android:textColor="#6B7280"
                        android:textStyle="italic"
                        android:layout_marginBottom="12dp"/>
                        
                    <EditText
                        android:id="@+id/etAnnounceTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Announcement Title"
                        android:background="@drawable/input_bg"
                        android:padding="12dp"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp"/>
                        
                    <EditText
                        android:id="@+id/etAnnounceMessage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Message content..."
                        android:background="@drawable/input_bg"
                        android:padding="12dp"
                        android:textSize="14sp"
                        android:minLines="3"
                        android:gravity="top|start"
                        android:layout_marginBottom="8dp"/>
                        
                    <Spinner
                        android:id="@+id/spinnerTargetRole"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/input_bg"
                        android:padding="12dp"
                        android:layout_marginBottom="12dp"/>
                        
                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnBroadcast"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Broadcast"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:background="@drawable/btn_orange"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            
        </LinearLayout>

        <!-- Navigation Placeholder/Sign Out -->
        <TextView
            android:id="@+id/tvSignOut"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sign Out"
            android:textColor="#6B7280"
            android:padding="12dp"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>
    </ScrollView>
</LinearLayout>
