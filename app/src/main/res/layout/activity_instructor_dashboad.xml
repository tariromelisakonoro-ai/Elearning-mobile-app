<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface">

    <!-- Nav Header -->
    <include layout="@layout/nav_header" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="16dp"
                android:text="Welcome to LearnExpress!"
                android:textColor="@color/primary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <!-- Profile Banner -->
            <LinearLayout
                android:id="@+id/cardProfile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/summary_banner_bg"
                android:orientation="vertical"
                android:padding="32dp"
                android:gravity="center_horizontal">

                <!-- Profile Image / Initial Circle -->
                <FrameLayout
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:background="@drawable/avatar_bg">
                    <TextView
                        android:id="@+id/tvInstructorInitial"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="M"
                        android:textColor="#FFFFFF"
                        android:textSize="40sp"
                        android:textStyle="bold"
                        android:gravity="center" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tvInstructorName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Melisa Lisa"
                    android:textColor="@color/heading"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Senior Instructor"
                    android:textColor="@color/primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <!-- Instructor Info Table -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:background="@drawable/card_bg"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="10dp"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Email"
                            android:textColor="@color/heading"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tvInstructorEmail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="melzs@gmail.com"
                            android:textColor="@color/muted"
                            android:textStyle="italic" />
                    </LinearLayout>
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="10dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        <TextView
                            android:id="@+id/tvStatusLabel"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Status"
                            android:textColor="@color/heading"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Approved – you can publish courses"
                            android:textColor="@color/successGreen"
                            android:background="@drawable/input_bg"
                            android:backgroundTint="@color/successBg"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="10dp"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Faculty"
                            android:textColor="@color/heading"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="General Staff"
                            android:textColor="@color/muted"
                            android:textStyle="italic" />
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- Creator Studio Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/auth_panel_bg"
                android:orientation="vertical"
                android:padding="28dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <FrameLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/icon_circle_bg">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_flash"
                            app:tint="@color/primary"
                            android:contentDescription="Icon" />
                    </FrameLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Creator Studio"
                        android:textColor="@color/heading"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Studio Tabs -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/input_bg"
                    android:padding="4dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tabAddCourse"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/card_bg"
                        android:paddingVertical="10dp"
                        android:text="📚 Add Course"
                        android:textColor="@color/primary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <TextView
                        android:id="@+id/tabAddExam"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:paddingVertical="10dp"
                        android:text="📝 Add Exam"
                        android:textColor="@color/muted"
                        android:textSize="12sp"
                        android:gravity="center" />

                    <TextView
                        android:id="@+id/tabAddResource"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:paddingVertical="10dp"
                        android:text="📎 Add Resource"
                        android:textColor="@color/muted"
                        android:textSize="12sp"
                        android:gravity="center" />

                    <TextView
                        android:id="@+id/tabAddAssignment"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:paddingVertical="10dp"
                        android:text="🎯 Add Assignment"
                        android:textColor="@color/muted"
                        android:textSize="12sp"
                        android:gravity="center" />
                </LinearLayout>

                <!-- 
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:text="Publish a New Course"
                    ... (Dummy Form Hidden) ...
                />
                -->

            </LinearLayout>

            <!-- Status Grid Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <!-- Your Courses -->
                <LinearLayout
                    android:id="@+id/containerYourCourses"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/card_bg"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Your Courses" android:textColor="@color/heading" android:textSize="16sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="No courses yet. Add your first one above!" android:textColor="@color/muted" android:textSize="12sp" android:textStyle="italic" />
                </LinearLayout>

                <View android:layout_width="16dp" android:layout_height="1dp" />

                <!-- Grading Queue -->
                <LinearLayout
                    android:id="@+id/containerGradingQueue"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/card_bg"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Grading Queue" android:textColor="@color/heading" android:textSize="16sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Verify and score student submissions." android:textColor="@color/muted" android:textSize="11sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="No submissions to grade yet." android:textColor="@color/muted" android:textSize="12sp" android:textStyle="italic" />
                </LinearLayout>

                <View android:layout_width="16dp" android:layout_height="1dp" />

                <!-- Course Requests -->
                <LinearLayout
                    android:id="@+id/containerCourseRequests"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/card_bg"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Course Requests" android:textColor="@color/heading" android:textSize="16sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Student enrollment applications." android:textColor="@color/muted" android:textSize="11sp" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:background="@drawable/input_bg" android:backgroundTint="#1A142A5B" android:padding="8dp" android:text="No pending requests." android:textColor="@color/heading" android:textSize="11sp" android:gravity="center" />
                </LinearLayout>
            </LinearLayout>

            <!-- Student Access Section -->
            <LinearLayout
                android:id="@+id/containerStudentAccess"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/card_bg"
                android:orientation="vertical"
                android:padding="24dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Student Access" android:textColor="@color/heading" android:textSize="16sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Approve new student accounts." android:textColor="@color/muted" android:textSize="12sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="No pending student registrations." android:textColor="@color/muted" android:textSize="13sp" android:textStyle="italic" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="40dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
