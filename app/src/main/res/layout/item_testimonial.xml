<?xml version="1.0" encoding="utf-8"?>
<!-- Website: .feature-card.testimonial-card -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="300dp"
    android:layout_height="match_parent"
    android:layout_margin="8dp"
    android:background="@drawable/testimonial_card_bg"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Website: .testimonial-stars { color: #f5a623; letter-spacing: 2px } -->
    <TextView
        android:id="@+id/tvStars"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="★★★★★"
        android:textColor="@color/starYellow"
        android:textSize="16sp"
        android:letterSpacing="0.08" />

    <!-- Website: .testimonial-quote { font-style: italic; color: var(-muted); line-height: 1.8 } -->
    <TextView
        android:id="@+id/tvQuote"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"
        android:layout_weight="1"
        android:lineSpacingExtra="4dp"
        android:text="&quot;Quote goes here&quot;"
        android:textColor="@color/muted"
        android:textSize="14sp"
        android:textStyle="italic" />

    <!-- Website: .testimonial-author { border-top: 1px solid rgba(35,51,91,0.08) } -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border"
        android:layout_marginBottom="14dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!-- Website: .testimonial-avatar { gradient, 2.8rem, border-radius: 50% } -->
        <TextView
            android:id="@+id/tvAvatar"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/avatar_bg"
            android:gravity="center"
            android:text="AA"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <!-- Website: .testimonial-author h4 { font-size: 0.95rem; color: var(-heading) } -->
            <TextView
                android:id="@+id/tvName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Name"
                android:textColor="@color/heading"
                android:textSize="15sp"
                android:textStyle="bold" />

            <!-- Website: .testimonial-author span { font-size: 0.8rem; color: var(-muted) } -->
            <TextView
                android:id="@+id/tvDetails"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Details"
                android:textColor="@color/muted"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>