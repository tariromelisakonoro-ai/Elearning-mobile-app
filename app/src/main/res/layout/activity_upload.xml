<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <include
        android:id="@+id/nav_bar"
        layout="@layout/nav_header"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/nav_bar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/tvUploadTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Upload Content"
                android:textColor="@color/heading"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tvLabelTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Title"
                android:textColor="@color/heading"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/input_bg"
                android:hint="Enter title"
                android:padding="16dp"
                android:textSize="14sp"
                android:textColorHint="@color/muted"
                android:textColor="@color/heading" />

            <!-- Dynamic spinner for Course Selection (hidden for Course upload) -->
            <LinearLayout
                android:id="@+id/layoutCourseSelection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select Course"
                    android:textColor="@color/heading"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <Spinner
                    android:id="@+id/spinnerCourses"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/input_bg"
                    android:paddingHorizontal="16dp" />
            </LinearLayout>

            <!-- Subject Category Selection (For courses) -->
            <LinearLayout
                android:id="@+id/layoutCategorySelection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp"
                android:visibility="gone">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select Subject Category"
                    android:textColor="@color/heading"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <Spinner
                    android:id="@+id/spinnerCategory"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/input_bg"
                    android:paddingHorizontal="16dp" />
            </LinearLayout>

            <!-- Document Type Selection (For resources) -->
            <LinearLayout
                android:id="@+id/layoutDocTypeSelection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp"
                android:visibility="gone">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select Document Type"
                    android:textColor="@color/heading"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <Spinner
                    android:id="@+id/spinnerDocType"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/input_bg"
                    android:paddingHorizontal="16dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvLabelDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Description"
                android:textColor="@color/heading"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp" />

            <EditText
                android:id="@+id/etDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/input_bg"
                android:hint="Enter description..."
                android:padding="16dp"
                android:textSize="14sp"
                android:textColorHint="@color/muted"
                android:textColor="@color/heading"
                android:minLines="4"
                android:gravity="top" />

            <TextView
                android:id="@+id/tvLabelExtra"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Extra Info (URL or Due Date)"
                android:textColor="@color/heading"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp" />

            <EditText
                android:id="@+id/etExtra"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/input_bg"
                android:hint="e.g. 2026-12-01 or https://link..."
                android:padding="16dp"
                android:textSize="14sp"
                android:textColorHint="@color/muted"
                android:textColor="@color/heading" />

            <!-- ───── File Attachment Section ───── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Attach a File (Optional)"
                android:textColor="@color/heading"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Accepted: PDF, DOC, DOCX, PPT, PPTX, TXT, MP4, ZIP, JPG, PNG"
                android:textColor="@color/muted"
                android:textSize="11sp"
                android:textStyle="italic"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="10dp" />

            <!-- Drop-zone style button -->
            <LinearLayout
                android:id="@+id/layoutFileDropZone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/input_bg"
                android:padding="24dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📎"
                    android:textSize="32sp"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/tvChooseFile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tap to choose a file"
                    android:textColor="@color/primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/tvSelectedFileName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No file selected"
                    android:textColor="@color/muted"
                    android:textSize="12sp"
                    android:textStyle="italic"
                    android:gravity="center"
                    android:layout_marginTop="6dp"
                    android:singleLine="true"
                    android:ellipsize="middle"
                    android:visibility="visible" />
            </LinearLayout>

            <!-- Selected file info chip -->
            <LinearLayout
                android:id="@+id/layoutFileChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/input_bg"
                android:backgroundTint="#E8F5E9"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp"
                android:layout_marginTop="8dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvFileChipIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📄"
                    android:textSize="16sp"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/tvFileChipName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="#2E7D32"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:singleLine="true"
                    android:ellipsize="middle" />

                <TextView
                    android:id="@+id/tvFileChipSize"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#6B7280"
                    android:textSize="11sp"
                    android:layout_marginStart="8dp" />

                <TextView
                    android:id="@+id/btnClearFile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" ✕"
                    android:textColor="#E53935"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginStart="10dp"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- Upload Progress -->
            <LinearLayout
                android:id="@+id/layoutUploadProgress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginTop="12dp">

                <TextView
                    android:id="@+id/tvUploadStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Uploading file..."
                    android:textColor="@color/primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <ProgressBar
                    android:id="@+id/progressBarUpload"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:indeterminate="true"
                    android:progressTint="@color/primary"
                    android:progressBackgroundTint="@color/surface" />
            </LinearLayout>

            <TextView
                android:id="@+id/btnSubmitUpload"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:background="@drawable/btn_orange"
                android:padding="14dp"
                android:text="Publish"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
