<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F9FB">

    <include layout="@layout/nav_header" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Parent Profile Card (Top) -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            android:backgroundTint="#FFFFFF"
            android:layout_marginBottom="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="40dp">

                <!-- Dynamic Avatar -->
                <FrameLayout
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:background="@drawable/avatar_bg"
                    android:backgroundTint="#F97316"
                    android:layout_marginBottom="16dp">
                    <TextView
                        android:id="@+id/tvProfileInitial"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="C"
                        android:textColor="#FFFFFF"
                        android:textSize="48sp"
                        android:textStyle="bold"
                        android:gravity="center"/>
                </FrameLayout>

                <!-- Dynamic Name -->
                <TextView
                    android:id="@+id/tvParentName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="cat"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#1a2a4a"
                    android:layout_marginBottom="4dp"/>

                <!-- Role Text -->
                <TextView
                    android:id="@+id/tvParentRole"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Parent / Guardian"
                    android:textSize="16sp"
                    android:textColor="#F97316"
                    android:textStyle="bold"/>

                <!-- Email Text -->
                <TextView
                    android:id="@+id/tvParentEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="parent@email.com"
                    android:textSize="14sp"
                    android:textColor="#6B7280"
                    android:textStyle="italic"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Select a Student Card (Bottom) -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            android:backgroundTint="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_school"
                        app:tint="#1a2a4a"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Select a Student"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#1a2a4a"/>
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Search for your child by name or email to view their academic dashboard."
                    android:textSize="14sp"
                    android:textColor="#6B7280"
                    android:layout_marginBottom="24dp"
                    android:textStyle="italic"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/studentInputLayout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:hintEnabled="false"
                        app:endIconMode="custom"
                        app:endIconDrawable="@drawable/ic_chevron_down"
                        app:endIconTint="#1a2a4a"
                        android:layout_marginEnd="12dp">

                        <AutoCompleteTextView
                            android:id="@+id/spinnerStudent"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="-- Select a student to view --"
                            android:inputType="none"
                            android:background="@drawable/input_bg"
                            android:padding="14dp"
                            android:textSize="14sp"
                            android:textColor="#1a2a4a"
                            android:focusable="false"
                            android:clickable="true"/>

                    </com.google.android.material.textfield.TextInputLayout>

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnViewStudent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="View Student"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:background="@drawable/btn_orange"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Container for Student Data (Hidden until student is selected) -->
        <LinearLayout
            android:id="@+id/containerStudentData"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- KPI Stats Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp"
                android:gravity="center">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:background="@drawable/card_bg" android:padding="16dp" android:layout_marginEnd="8dp">
                    <TextView android:id="@+id/tvKpiActiveCourses" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#F97316" android:textSize="24sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Active Courses" android:textColor="#6B7280" android:textSize="11sp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:background="@drawable/card_bg" android:padding="16dp" android:layout_marginEnd="8dp">
                    <TextView android:id="@+id/tvKpiGradedWork" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#16A34A" android:textSize="24sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Graded Work" android:textColor="#6B7280" android:textSize="11sp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:background="@drawable/card_bg" android:padding="16dp" android:layout_marginEnd="8dp">
                    <TextView android:id="@+id/tvKpiPendingGrades" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#EA580C" android:textSize="24sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pending Grades" android:textColor="#6B7280" android:textSize="11sp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:background="@drawable/card_bg" android:padding="16dp">
                    <TextView android:id="@+id/tvKpiUpcomingTasks" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#9333EA" android:textSize="24sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Upcoming Tasks" android:textColor="#6B7280" android:textSize="11sp"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false">
                
                <!-- Academic Progress -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.2"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    android:layout_marginEnd="8dp"
                    android:backgroundTint="#FFFFFF"
                    android:layout_marginBottom="24dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Academic Progress" android:textSize="18sp" android:textStyle="bold" android:textColor="#1a2a4a" android:layout_marginBottom="4dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Course completion estimates based on enrollment activity." android:textSize="12sp" android:textColor="#6B7280" android:textStyle="italic" android:layout_marginBottom="12dp"/>
                        <LinearLayout android:id="@+id/containerAcademicProgress" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
                
                <!-- Upcoming Tasks -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.8"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    android:layout_marginStart="8dp"
                    android:backgroundTint="#FFFFFF"
                    android:layout_marginBottom="24dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Upcoming Tasks" android:textSize="18sp" android:textStyle="bold" android:textColor="#1a2a4a" android:layout_marginBottom="12dp"/>
                        <LinearLayout android:id="@+id/containerUpcomingTasks" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Grades & Performance -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                android:backgroundTint="#FFFFFF"
                android:layout_marginBottom="24dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Grades &amp; Performance" android:textSize="18sp" android:textStyle="bold" android:textColor="#1a2a4a" android:layout_marginBottom="4dp"/>
                    <TextView android:id="@+id/tvGradesSubtitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="All graded work submitted." android:textSize="12sp" android:textColor="#6B7280" android:textStyle="italic" android:layout_marginBottom="12dp"/>
                    <LinearLayout android:id="@+id/containerGrades" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Report Summary -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="24dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/summary_banner_bg"
                    android:padding="24dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Academic Report Summary" android:textSize="18sp" android:textStyle="bold" android:textColor="#1a2a4a" android:layout_marginBottom="12dp"/>
                    <TextView android:id="@+id/tvReportSummary" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="" android:textColor="#1a2a4a" android:textSize="14sp" android:lineSpacingExtra="4dp" android:layout_marginBottom="16dp"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <androidx.appcompat.widget.AppCompatButton android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="View Courses" android:textAllCaps="false" android:textColor="#FFFFFF" android:background="@drawable/btn_orange" android:layout_marginEnd="8dp"/>
                        <androidx.appcompat.widget.AppCompatButton android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="View Assignments" android:textAllCaps="false" android:textColor="#FFFFFF" android:background="@drawable/btn_orange"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <TextView
            android:id="@+id/tvSignOut"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sign Out"
            android:textColor="#6B7280"
            android:layout_marginTop="8dp"
            android:padding="12dp"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>
    </ScrollView>
</LinearLayout>
