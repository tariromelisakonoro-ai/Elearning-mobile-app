<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Payments &amp; Invoices"
        android:textColor="@color/heading"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginTop="32dp"
        android:layout_marginStart="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Balance Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardBalance"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Balance Remaining"
                android:textColor="@color/muted"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$1,200.00"
                android:textColor="@color/heading"
                android:textSize="36sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tvRecentInvoices"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Recent Invoices"
        android:textColor="@color/heading"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp"
        android:layout_marginStart="24dp"
        app:layout_constraintTop_toBottomOf="@id/cardBalance"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Dummy Invoice List -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvRecentInvoices">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="INV-2026-001 • Term 3 Tuition\nAmount: $800.00 | Status: Unpaid"
            android:padding="16dp"
            android:background="@drawable/card_bg"
            android:textColor="@color/text"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="INV-2026-002 • Hostel Fees\nAmount: $400.00 | Status: Unpaid"
            android:padding="16dp"
            android:background="@drawable/card_bg"
            android:textColor="@color/text"
            android:layout_marginBottom="12dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
